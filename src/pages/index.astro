---
const title = "MCP Atlas";
const description = "A curated directory of real, verified MCP servers.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<main>
			<h1>{title}</h1>
			<p>{description}</p>
			<p>Directory content is being seeded — check back soon.</p>
		</main>
	</body>
</html>
