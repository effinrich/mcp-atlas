---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found — MCP Atlas" description="This page doesn't exist.">
  <div class="text-center py-24">
    <p class="text-sm font-mono text-zinc-400 mb-4">404</p>
    <h1 class="text-2xl font-semibold mb-4">That entry doesn't exist</h1>
    <p class="text-zinc-400 mb-8">
      The server you're looking for might have been renamed or removed. Head back and search
      instead.
    </p>
    <a
      href="/"
      class="inline-block px-4 py-2 bg-zinc-100 text-zinc-950 font-medium rounded hover:bg-white transition-colors"
    >
      Back to MCP Atlas
    </a>
  </div>
</BaseLayout>
